# Filled by `shopify app config link` / `shopify app dev`, or set in your host.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://first-order-discount.example.com
SCOPES=write_discounts

# Shared factory knobs (optional — sensible defaults in @factory/core)
STARTER_PRICE=4.99
PRO_PRICE=9.99
TRIAL_DAYS=7
BILLING_CURRENCY=USD

# Funnel analytics: leave blank to log to console, or point at a collector.
FACTORY_ANALYTICS_URL=
FACTORY_APP=first-order-discount

# Prisma (session storage). SQLite for dev; swap to DO Managed Postgres in prod.
DATABASE_URL="file:./prisma/dev.sqlite"
